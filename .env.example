# Copy to .env and adjust for your machine.
# This repo ignores .env on purpose (see root .gitignore).

# Postgres (docker-compose)
POSTGRES_DB=videoportal
POSTGRES_USER=videoportal
POSTGRES_PASSWORD=change-me

# Optional admin seeding on backend startup (opt-in)
APP_ADMIN_ENABLED=false
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me
APP_ADMIN_ROLE=1
